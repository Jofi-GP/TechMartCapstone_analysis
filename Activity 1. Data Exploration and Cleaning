-- Step 5: Try it yourself: Clean inconsistent data in other tables
# Your turn: Clean inconsistent data in other tables
query_sales = """
UPDATE Sales_Transactions
SET total_amount = CASE WHEN total_amount = 'nan' THEN NULL ELSE total_amount END,
    quantity = CASE WHEN quantity = 'three' THEN '3' ELSE quantity END,
    employee_id = CASE WHEN employee_id IS NULL OR employee_id = 'NaN' THEN 'Unknown' 
    ELSE employee_id END
    
"""
query_customer = """
UPDATE Customer_Demographics
SET age = CASE WHEN age = 'None' OR age IS NULL THEN 'Unknown' ELSE age END,
    loyalty_program = CASE 
        WHEN loyalty_program IS NULL THEN 'Unknown'
        WHEN LOWER(loyalty_program) = 'None' THEN 'No' 
        WHEN LOWER(loyalty_program) = 'no' THEN 'No'
        ELSE loyalty_program END
    
"""
query_product = """
UPDATE Product_Details
SET price = CASE 
    WHEN LOWER(TRIM(price)) = 'one'         THEN '1'
    WHEN LOWER(TRIM(price)) = 'two'         THEN '2'
    WHEN LOWER(TRIM(price)) = 'three'       THEN '3'
    WHEN LOWER(TRIM(price)) = 'ten'         THEN '10'
    WHEN LOWER(TRIM(price)) = 'twenty'      THEN '20'
    WHEN LOWER(TRIM(price)) = 'fifty'       THEN '50'
    WHEN LOWER(TRIM(price)) = 'one hundred'  THEN '100'
    WHEN LOWER(TRIM(price)) = 'two hundred'  THEN '200'
    ELSE price -- Keeps regular numbers like '45' completely safe
END
"""
try:
    cursor = conn.cursor()
    cursor.execute("BEGIN TRANSACTION;")
    cursor.execute(query_sales)
    cursor.execute(query_customer)
    cursor.execute(query_product)
    conn.commit()
    print("All tables successfully cleaned and saved!")

except Exception as e:
    # If a single typo or error happens anywhere, undo everything safely
    conn.rollback()
    print(f"Transaction failed! Safely rolled back all changes. Error: {e}")

