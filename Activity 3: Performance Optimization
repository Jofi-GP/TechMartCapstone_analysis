import time
start_time = time.time()
query = """
WITH StoreSales AS (
   SELECT
       e.store_location,
       e.employee_id,
       e.role,
       p.category,
       c.loyalty_program,
       COUNT(s.transaction_id) AS total_sales,
       SUM(s.quantity) AS total_units_sold,
       SUM(s.total_amount) AS total_revenue,
       
       -- WINDOW FUNCTION: Calculates total store revenue per category 
       -- without needing a separate GROUP BY or JOIN step later.
       SUM(SUM(s.total_amount)) OVER(
           PARTITION BY e.store_location, p.category
       ) AS store_revenue
       
   FROM Sales_Transactions s
   JOIN Employee_Records e ON s.employee_id = e.employee_id
   JOIN Product_Details p ON s.product_id = p.product_id
   JOIN Customer_Demographics c ON s.customer_id = c.customer_id
   WHERE p.category IN ('Electronics', 'Accessories')
   GROUP BY e.store_location, e.employee_id, e.role, p.category, c.loyalty_program
)
SELECT
   store_location,
   employee_id,
   role,
   category,
   loyalty_program,
   total_sales,
   total_units_sold,
   total_revenue
FROM StoreSales
ORDER BY store_location, total_revenue DESC;
"""

df_store_sales = pd.read_sql_query(query, conn)

